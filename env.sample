# Renomeie este arquivo para .env e preencha os valores.
# Em producao no Easypanel, configure essas variaveis na aba "Environment".

# Servidor
PORT=3001
NODE_ENV=production

# MongoDB (no Easypanel, use o hostname interno do servico Mongo)
MONGODB_URI=mongodb://mongo:27017/liameddis

# JWT (gere um novo: openssl rand -base64 48)
JWT_SECRET=troque-isso-por-um-secret-forte

# Uazapi
UAZAPI_URL=https://liaautomacoes.uazapi.com
# Token de instancia unica (opcional se voce for usar gestao multi-instancia)
UAZAPI_TOKEN=seu-token-uazapi
# Admin token (OBRIGATORIO para criar novas instancias pela tela /instancias)
UAZAPI_ADMIN_TOKEN=seu-admin-token-uazapi
UAZAPI_PHONE=5511999999999

# CORS — em producao use o dominio do frontend (ou * se servir do mesmo host)
CORS_ORIGIN=*

# Webhook (opcional — Uazapi callback)
WEBHOOK_SECRET=gere-outro-secret-aqui
